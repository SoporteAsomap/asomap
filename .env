# Configuración de la base de datos
DB_USER=asomap_user
DB_PASS=asomap_password
DB_NAME=asomap
DB_HOST=db
DB_PORT=5432
USE_DOCKER_DB=True

# Configuración de Django
DEBUG=False
SECRET_KEY=Tl4-mwGW_FOhn0JC1hcTo1npECoAk3bTWTyeMBA9a6JUm3WbNJ2pHhy0RfRf_n7gcoM

# Configuración del servidor (cambiar por tu IP real)
SERVER_IP=192.168.54.10
SERVER_PORT=8080
SERVER_PROTOCOL=http

# Configuración del frontend para producción
VITE_ENV=production
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Hosts permitidos (se generan automáticamente desde SERVER_IP)
ALLOWED_HOSTS=127.0.0.1,0.0.0.0,${SERVER_IP}

# Orígenes CORS permitidos (se generan automáticamente desde SERVER_IP)
CORS_ALLOWED_ORIGINS=http://192.168.54.10:8080,http://localhost:8080,http://127.0.0.1:8080,http://localhost:3000,http://127.0.0.1:3000,${SERVER_PROTOCOL}://${SERVER_IP}:${SERVER_PORT}

# Orígenes CSRF confiables (se generan automáticamente desde SERVER_IP)
CSRF_TRUSTED_ORIGINS=${SERVER_PROTOCOL}://${SERVER_IP}:${SERVER_PORT},${SERVER_PROTOCOL}://${SERVER_IP}

# Configuración del frontend
VITE_API_URL=http://192.168.54.10:8080

# Configuración de medios
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles
