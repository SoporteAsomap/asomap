# Environment Configuration
VITE_ENV=development

# Server Configuration (loaded from root .env)
# SERVER_IP, SERVER_PORT, SERVER_PROTOCOL are loaded from parent directory

# API Configuration
VITE_API_BASE_URL=http://192.168.54.10:8080/api
VITE_BACKEND_URL=http://192.168.54.10:8000
VITE_MEDIA_BASE_URL=http://192.168.54.10:8080/media
VITE_NGINX_URL=http://192.168.54.10:8080

# External APIs
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Feature Flags (optional - not used in current code)
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=false

# Development Settings (not used in current code)
VITE_DEBUG_LOGS=true
VITE_MOCK_DATA=true
